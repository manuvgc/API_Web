{
  "name": "api_vendas",
  "version": "1.0.0",
  "description": "sistema de controle de produtos, clientes e pedidos",
  "license": "ISC",
  "author": "manuvgc",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --inspect -r tsconfig-paths/register --transpile-only --ignore-watch node_modules src/shared/http/server.ts",
    "migration:run": "npm run typeorm --  migration:run -d src/shared/typeorm/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate -d src/shared/typeorm/data-source.ts",
    "typeorm": "typeorm-ts-node-commonjs -d src/shared/typeorm/data-source.ts",
    "migration:revert": "npm run typeorm migration:revert"
  },
  "dependencies": {
    "celebrate": "^15.0.3",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "ts-node-dev": "^2.0.0",
    "typeorm": "^0.3.28",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/joi": "^17.2.2",
    "@types/node": "^25.5.0",
    "tsconfig-paths": "^4.2.0"
  }
}
